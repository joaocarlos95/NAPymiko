!
hostname {{ device.hostname }}
username warpcom privilege 15 algorithm-type scrypt secret Warpcom.2022
!
aaa new-model
aaa authentication login default {{ device.aaa_default_method_list | default("local"}}
aaa authentication login default {{ device.aaa_default_method_list | default("local"}}
aaa authorization exec default {{ device.aaa_default_method_list | default("local"}} if-authenticated
aaa authorization console
aaa authorization config-commands
!
crypto key generate rsa general-keys modulus 2048
!
no ip domain lookup
no ip http server
{% if "http" in device.authentication_methods %}
    ip http secure server
    ip http authentication aaa
{% endif %}
!
domain-name {{ device.domain_name }}
!
{% include "cisco_ios_vlans.j2" %}
!
{% include "cisco_ios_interfaces.j2" %}
!
{% include "cisco_ios_ip_addresses.j2" %}
!
{% include "cisco_ios_routes.j2" %}
!
!
line con 0
    logging synchronous
line vty 0 4
    logging synchronous
    transport input ssh
line vty 5 15
    logging synchronous
    transport input ssh
!
